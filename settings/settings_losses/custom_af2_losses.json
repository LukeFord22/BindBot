{
  "description": "Custom AF2 loss configuration for compact/rigid binder design",
  "_note": "All weights should be small (0.01-0.2) to avoid dominating binding/interface losses",

  "rg_loss": {
    "enabled": false,
    "weight": 0.05,
    "_description": "Penalize large radius of gyration (promotes compact binders)"
  },

  "intrachain_contact_loss": {
    "enabled": false,
    "weight": 0.1,
    "distance_threshold": 8.0,
    "_description": "Reward intrachain contacts (promotes rigid, well-packed binders)"
  },

  "low_plddt_penalty": {
    "enabled": false,
    "weight": 0.08,
    "plddt_threshold": 70,
    "_description": "Penalize low confidence regions"
  },

  "terminal_looseness_penalty": {
    "enabled": false,
    "weight": 0.05,
    "n_term_residues": 3,
    "c_term_residues": 3,
    "max_bfactor": 50,
    "_description": "Penalize flexible termini (promotes structured ends)"
  },

  "loop_flexibility_penalty": {
    "enabled": false,
    "weight": 0.05,
    "_description": "Penalize disordered loops"
  },

  "secondary_structure_bias": {
    "enabled": false,
    "weight": 0.1,
    "prefer_helix": true,
    "_description": "Bias toward helical (true) or sheet (false) secondary structure"
  },

  "helix_loss": {
    "enabled": false,
    "weight": 0.1,
    "_description": "Promote alpha-helical structure (i, i+3/i+4 contacts)"
  },

  "termini_distance_loss": {
    "enabled": false,
    "weight": 0.05,
    "threshold_distance": 7.0,
    "_description": "Keep N and C termini close together (for cyclic-like topology)"
  },

  "_usage_examples": {
    "_compact_rigid_binder": {
      "rg_loss": {"enabled": true, "weight": 0.05},
      "intrachain_contact_loss": {"enabled": true, "weight": 0.1},
      "low_plddt_penalty": {"enabled": true, "weight": 0.08}
    },
    "_helical_binder": {
      "helix_loss": {"enabled": true, "weight": 0.15},
      "secondary_structure_bias": {"enabled": true, "weight": 0.1, "prefer_helix": true}
    },
    "_structured_termini": {
      "terminal_looseness_penalty": {"enabled": true, "weight": 0.08},
      "termini_distance_loss": {"enabled": true, "weight": 0.05}
    }
  }
}
